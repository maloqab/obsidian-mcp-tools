{
  "name": "obsidian-mcp-tools",
  "version": "0.1.0",
  "description": "The complete Obsidian MCP server -- 43 tools for search, graph, tags, Dataview, frontmatter, canvas, templates, and more",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "obsidian-mcp-tools": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "obsidian",
    "mcp",
    "model-context-protocol",
    "vault",
    "notes",
    "knowledge-base",
    "search",
    "dataview",
    "graph",
    "ai",
    "llm",
    "claude",
    "chatgpt"
  ],
  "author": "maloqab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maloqab/obsidian-mcp-tools.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "chokidar": "^4.0.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
